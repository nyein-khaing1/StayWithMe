<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="StayWithMe.MainPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#FFF7F9">

    <Grid>

        <Image x:Name="ChatBackgroundImage"
               Aspect="AspectFill"
               HorizontalOptions="Fill"
               VerticalOptions="Fill"/>

        <BoxView Color="#000000"
                 Opacity="0.08"/>

        <Grid Padding="26"
              ColumnDefinitions="*,620"
              RowDefinitions="Auto,*"
              ColumnSpacing="26"
              RowSpacing="18">

            <Button Grid.Row="0"
                    Grid.Column="0"
                    Text="←"
                    FontSize="27"
                    WidthRequest="56"
                    HeightRequest="56"
                    Padding="0"
                    HorizontalOptions="Start"
                    BackgroundColor="#EFFFFFFF"
                    TextColor="#25202A"
                    CornerRadius="28"
                    Clicked="OnChangeCharacterClicked"/>

            <Border x:Name="HeaderBorder"
                    Grid.Row="0"
                    Grid.Column="1"
                    HeightRequest="82"
                    Padding="14,10"
                    BackgroundColor="#F2FFFFFF"
                    Stroke="#DDFFFFFF"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 25">

                <Grid ColumnDefinitions="Auto,*,Auto"
                      ColumnSpacing="13">

                    <Image x:Name="AvatarImage"
                           Grid.Column="0"
                           WidthRequest="58"
                           HeightRequest="58"
                           Aspect="AspectFill"
                           VerticalOptions="Center">

                        <Image.Clip>
                            <EllipseGeometry Center="29,29"
                                             RadiusX="29"
                                             RadiusY="29"/>
                        </Image.Clip>
                    </Image>

                    <VerticalStackLayout Grid.Column="1"
                                         Spacing="2"
                                         VerticalOptions="Center">

                        <Label x:Name="NameLabel"
                               FontSize="25"
                               FontAttributes="Bold"/>

                        <HorizontalStackLayout Spacing="6">
                            <Ellipse WidthRequest="9"
                                     HeightRequest="9"
                                     Fill="#19AF67"
                                     VerticalOptions="Center"/>

                            <Label Text="Online now"
                                   FontSize="13"
                                   TextColor="#5C5360"
                                   VerticalOptions="Center"/>
                        </HorizontalStackLayout>
                    </VerticalStackLayout>

                    <HorizontalStackLayout Grid.Column="2"
                                           Spacing="10"
                                           VerticalOptions="Center">

                        <Button Text="⋯"
                                WidthRequest="44"
                                HeightRequest="44"
                                Padding="0"
                                BackgroundColor="#FFEAF1"
                                TextColor="#EA3975"
                                FontSize="24"
                                CornerRadius="22"
                                Clicked="OnChatMenuClicked"/>

                    </HorizontalStackLayout>

                </Grid>
            </Border>

            <Border Grid.Row="1"
                    Grid.Column="0"
                    Margin="0,0,0,20"
                    Padding="14"
                    WidthRequest="310"
                    HorizontalOptions="Start"
                    VerticalOptions="End"
                    BackgroundColor="#DFFFFFFF"
                    Stroke="#AFFFFFFF"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 24">

                <Grid ColumnDefinitions="Auto,*"
                      ColumnSpacing="12">

                    <Image x:Name="ChatAvatarImage"
                           Grid.Column="0"
                           WidthRequest="64"
                           HeightRequest="64"
                           Aspect="AspectFill"
                           VerticalOptions="Center">

                        <Image.Clip>
                            <EllipseGeometry Center="32,32"
                                             RadiusX="32"
                                             RadiusY="32"/>
                        </Image.Clip>
                    </Image>

                    <VerticalStackLayout Grid.Column="1"
                                         Spacing="3"
                                         VerticalOptions="Center">

                        <Label x:Name="CharacterNameLabel"
                               FontSize="23"
                               FontAttributes="Bold"/>

                        <Label x:Name="PersonalityLabel"
                               FontSize="14"
                               TextColor="#625865"
                               LineBreakMode="WordWrap"/>

                        <Label x:Name="RelationshipLabel"
                               FontSize="13"
                               FontAttributes="Bold"
                               TextColor="#EA3975"/>
                    </VerticalStackLayout>

                </Grid>
            </Border>

            <Border Grid.Row="1"
                    Grid.Column="1"
                    Padding="20"
                    BackgroundColor="#EEFFFFFF"
                    Stroke="#CCFFFFFF"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 30">

                <Grid RowDefinitions="Auto,*,Auto,Auto"
                      RowSpacing="12">

                    <Border Grid.Row="0"
                            Padding="13"
                            BackgroundColor="#AFFFFFFF"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 21">

                        <Grid ColumnDefinitions="Auto,*"
                              ColumnSpacing="12">

                            <Image WidthRequest="48"
                                   HeightRequest="48"
                                   Source="{Binding Source={x:Reference ChatAvatarImage}, Path=Source}"
                                   Aspect="AspectFill"
                                   VerticalOptions="Center">

                                <Image.Clip>
                                    <EllipseGeometry Center="24,24"
                                                     RadiusX="24"
                                                     RadiusY="24"/>
                                </Image.Clip>
                            </Image>

                            <VerticalStackLayout Grid.Column="1"
                                                 Spacing="1"
                                                 VerticalOptions="Center">

                                <Label Text="{Binding Source={x:Reference CharacterNameLabel}, Path=Text}"
                                       FontSize="20"
                                       FontAttributes="Bold"
                                       TextColor="{Binding Source={x:Reference CharacterNameLabel}, Path=TextColor}"/>

                                <Label Text="{Binding Source={x:Reference PersonalityLabel}, Path=Text}"
                                       FontSize="13"
                                       TextColor="#625865"/>
                            </VerticalStackLayout>

                        </Grid>
                    </Border>

                    <ScrollView x:Name="ChatScroll"
                                Grid.Row="1"
                                VerticalScrollBarVisibility="Default">

                        <VerticalStackLayout x:Name="ChatContainer"
                                             Padding="2,8,4,8"
                                             Spacing="13"/>
                    </ScrollView>

                    <Label x:Name="TypingLabel"
                           Grid.Row="2"
                           IsVisible="False"
                           Margin="8,0"
                           FontSize="13"
                           FontAttributes="Italic"
                           TextColor="#665E69"/>

                    <Border x:Name="InputBorder"
                            Grid.Row="3"
                            Padding="7"
                            BackgroundColor="#FAFFFFFF"
                            StrokeThickness="2"
                            StrokeShape="RoundRectangle 29">

                        <Grid ColumnDefinitions="*,Auto"
                              ColumnSpacing="8">

                            <Entry x:Name="UserInput"
                                   Grid.Column="0"
                                   Placeholder="Type a message..."
                                   PlaceholderColor="#A49AA7"
                                   TextColor="#2C2730"
                                   FontSize="16"
                                   ReturnType="Send"
                                   Completed="OnUserInputCompleted"
                                   BackgroundColor="Transparent"
                                   Margin="12,0"/>

                            <Button x:Name="SendButton"
                                    Grid.Column="1"
                                    Text="➤"
                                    FontSize="21"
                                    WidthRequest="50"
                                    HeightRequest="50"
                                    Padding="0"
                                    TextColor="White"
                                    CornerRadius="25"
                                    Clicked="OnSendClicked"/>

                        </Grid>
                    </Border>

                </Grid>
            </Border>

        </Grid>
    </Grid>
</ContentPage>