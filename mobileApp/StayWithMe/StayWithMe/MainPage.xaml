<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="StayWithMe.MainPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#FFF7F9">

    <Grid>

        <!-- Full desktop background -->
        <Image x:Name="ChatBackgroundImage"
               Aspect="AspectFill"
               HorizontalOptions="Fill"
               VerticalOptions="Fill"/>

        <!-- Light overlay so the interface stays readable -->
        <BoxView Color="Black"
                 Opacity="0.08"/>

        <Grid Padding="28"
              RowDefinitions="Auto,*">

            <!-- Top navigation header -->
            <Border x:Name="HeaderBorder"
                    Grid.Row="0"
                    HeightRequest="84"
                    Padding="16,10"
                    BackgroundColor="#F4FFFFFF"
                    Stroke="#DDFFFFFF"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 26">

                <Grid ColumnDefinitions="Auto,Auto,*,Auto"
                      ColumnSpacing="14">

                    <Button Grid.Column="0"
                            Text="←"
                            FontSize="27"
                            WidthRequest="54"
                            HeightRequest="54"
                            Padding="0"
                            BackgroundColor="#22FFFFFF"
                            TextColor="#25202A"
                            CornerRadius="27"
                            Clicked="OnChangeCharacterClicked"/>

                    <!-- Circular character avatar -->
                    <Image Grid.Column="1"
                           x:Name="AvatarImage"
                           WidthRequest="58"
                           HeightRequest="58"
                           Aspect="AspectFill">

                        <Image.Clip>
                            <EllipseGeometry Center="29,29"
                                             RadiusX="29"
                                             RadiusY="29"/>
                        </Image.Clip>
                    </Image>

                    <VerticalStackLayout Grid.Column="2"
                                         Spacing="1"
                                         VerticalOptions="Center">

                        <Label x:Name="NameLabel"
                               FontSize="25"
                               FontAttributes="Bold"/>

                        <HorizontalStackLayout Spacing="6">
                            <Ellipse WidthRequest="9"
                                     HeightRequest="9"
                                     Fill="#19AF67"
                                     VerticalOptions="Center"/>

                            <Label Text="Online now"
                                   FontSize="13"
                                   TextColor="#5C5360"/>
                        </HorizontalStackLayout>
                    </VerticalStackLayout>

                    <Button Grid.Column="3"
                            Text="Change character"
                            Padding="20,10"
                            BackgroundColor="#22FFFFFF"
                            TextColor="#352E38"
                            CornerRadius="20"
                            Clicked="OnChangeCharacterClicked"/>

                </Grid>
            </Border>

            <!-- Desktop body: character visible left, chat on right -->
            <Grid Grid.Row="1"
                  Margin="0,20,0,0"
                  ColumnDefinitions="*,600"
                  ColumnSpacing="28">

                <!-- Empty left side deliberately reveals character -->
                <Grid Grid.Column="0"/>

                <!-- Chat glass panel -->
                <Border Grid.Column="1"
                        Padding="20"
                        BackgroundColor="#EDFFFFFF"
                        Stroke="#CCFFFFFF"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 30">

                    <Grid RowDefinitions="Auto,*,Auto,Auto"
                          RowSpacing="12">

                        <!-- Character details inside chat -->
                        <Border Grid.Row="0"
                                Padding="14"
                                BackgroundColor="#BFFFFFFF"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 22">

                            <Grid ColumnDefinitions="66,*"
                                  ColumnSpacing="12">

                                <Image x:Name="ChatAvatarImage"
                                       WidthRequest="60"
                                       HeightRequest="60"
                                       Aspect="AspectFill">

                                    <Image.Clip>
                                        <EllipseGeometry Center="30,30"
                                                         RadiusX="30"
                                                         RadiusY="30"/>
                                    </Image.Clip>
                                </Image>

                                <VerticalStackLayout Grid.Column="1"
                                                     VerticalOptions="Center"
                                                     Spacing="2">

                                    <Label x:Name="CharacterNameLabel"
                                           FontSize="22"
                                           FontAttributes="Bold"/>

                                    <Label x:Name="PersonalityLabel"
                                           FontSize="14"
                                           TextColor="#625865"/>
                                </VerticalStackLayout>

                            </Grid>
                        </Border>

                        <!-- Messages -->
                        <ScrollView Grid.Row="1"
                                    x:Name="ChatScroll">

                            <VerticalStackLayout x:Name="ChatContainer"
                                                 Padding="2,8"
                                                 Spacing="12"/>
                        </ScrollView>

                        <!-- Typing status -->
                        <Label Grid.Row="2"
                               x:Name="TypingLabel"
                               IsVisible="False"
                               FontSize="13"
                               FontAttributes="Italic"
                               TextColor="#665E69"
                               Margin="8,0"/>

                        <!-- Message input -->
                        <Border Grid.Row="3"
                                x:Name="InputBorder"
                                Padding="7"
                                BackgroundColor="White"
                                StrokeThickness="2"
                                StrokeShape="RoundRectangle 28">

                            <Grid ColumnDefinitions="*,Auto"
                                  ColumnSpacing="8">

                                <Entry x:Name="UserInput"
                                       Placeholder="Type a message..."
                                       PlaceholderColor="#A49AA7"
                                       TextColor="#2C2730"
                                       FontSize="16"
                                       ReturnType="Send"
                                       Completed="OnUserInputCompleted"
                                       BackgroundColor="Transparent"
                                       Margin="10,0"/>

                                <Button Grid.Column="1"
                                        x:Name="SendButton"
                                        Text="➤"
                                        FontSize="21"
                                        WidthRequest="50"
                                        HeightRequest="50"
                                        Padding="0"
                                        TextColor="White"
                                        CornerRadius="25"
                                        Clicked="OnSendClicked"/>
                            </Grid>
                        </Border>

                    </Grid>
                </Border>

            </Grid>
        </Grid>

    </Grid>
</ContentPage>